PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_here

# Google Gemini API key (https://aistudio.google.com/apikey) — never commit the real key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: preferred model (falls back to others if quota hit)
# GEMINI_MODEL=gemini-2.5-flash
